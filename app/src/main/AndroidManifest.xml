<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Android 11 and lower -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30"/>

    <!-- Android 12 and higher -->
    <!-- Declares the app looks for Bluetooth devices, but never derives physical location
     from scan results -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"/>
    <!-- Declares the app communicates with already-paired Bluetooth devices -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.COEN390">

        <activity
            android:name=".ActivityLogScreen"
            android:exported="false"
            android:theme="@style/Theme.COEN390" />

        <activity
            android:name=".SessionDetailsScreen" />

        <activity
            android:name=".ModeScreen"
            android:exported="false"
            android:label="COEN390"
            android:theme="@style/Theme.COEN390" />

        <activity
            android:name=".WelcomeScreen"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.COEN390">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>